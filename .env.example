# Payload CMS - Environment Variables Template
# Copy this file to .env and fill in the values

# Secret used to encrypt sessions (Generate a random 32-byte string)
PAYLOAD_SECRET=

# Port the server will listen on
PORT=3001

# Public URL of your site (Crucial for Next.js and Payload)
NEXT_PUBLIC_SERVER_URL=https://yourdomain.com

# SQLite Database connection string
DATABASE_URL=file:./payload.db

# Directory for media uploads
MEDIA_DIR=./media

# Email Configuration (SMTP)
SMTP_HOST=
SMTP_USER=
SMTP_PASS=
SMTP_PORT=587
SMTP_FROM_ADDRESS=contato@yourdomain.com
SMTP_FROM_NAME=Your Name
